{
  "manifest_version": 3,
  "name": "Drop Your Phone",
  "version": "0.0.2",
  "minimum_chrome_version": "109",
  "description": "Block cookie trackers and opt out of data brokers. A social justice art piece about ICE and data broker surveillance.",
  "permissions": ["activeTab", "alarms", "cookies", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://checkpeople.com/opt-out*",
        "https://freepeoplesearch.com/opt-out*",
        "https://www.officialusa.com/opt-out*",
        "https://clustrmaps.com/bl/opt-out*",
        "https://www.truepeoplesearch.com/removal*",
        "https://www.searchpeoplefree.com/opt-out*",
        "https://nuwber.com/removal/*",
        "https://www.usphonebook.com/removal*",
        "https://www.peoplesearchnow.com/opt-out*",
        "https://www.phonebooks.com/opt-out*",
        "https://neighbor.report/remove*",
        "https://centeda.com/ng/control/privacy*",
        "https://vericora.com/ng/control/privacy*",
        "https://www.advancedbackgroundchecks.com/removal*",
        "https://thatsthem.com/optout*",
        "https://www.archives.com/optout*",
        "https://www.acxiom.com/optout/*",
        "https://socialcatfish.com/opt-out/*",
        "https://mylife.jotform.com/*",
        "https://www.spyfly.com/help-center/privacy-requests*",
        "https://www.peoplebyname.com/remove.php*",
        "https://blockshopper.com/page/opt_out*",
        "https://publicdatausa.com/remove.php*",
        "https://golookup.com/ng/control/privacy*",
        "https://www.clubset.com/ng/control/privacy*",
        "https://www.kwold.com/ng/control/privacy*",
        "https://pub360.com/ng/control/privacy*",
        "https://www.zoominfo.com/update/opt-out*",
        "https://www.veromi.net/privacy*",
        "https://www.privateeye.com/opt-out*",
        "https://www.usa-people-search.com/manage/optout*",
        "https://www.allareacodes.com/opt_out*",
        "https://homemetry.com/opt-out*",
        "https://pipl.com/optout*",
        "https://www.criminalwatchdog.com/removal*",
        "https://ibackgroundcheck.com/removal*",
        "https://www.peoplewhiz.com/optout*",
        "https://www.numberhub.com/opt-out*",
        "https://www.courtrecord.net/opt-out*",
        "https://datacloudoptout.oracle.com/*",
        "https://optout.liveramp.com/*",
        "https://infofree.com/opt-out/*",
        "https://www.findpeoplefast.net/opt-out*",
        "https://www.birthdatabase.com/opt-out*",
        "https://www.epsilon.com/us/about-us/data-subject-request*",
        "https://www.phonedetective.com/PD.aspx*",
        "https://www.peoplesearchsite.com/optout*",
        "https://www.courtpublicrecords.com/opt-out*",
        "https://www.publicphonerecords.com/opt-out*",
        "https://www.person-lookup.com/opt-out*",
        "https://www.classmates.com/privacy/consumer-request*",
        "https://peoplelookupfree.com/optout*",
        "https://www.usatrace.com/opt-out*",
        "https://www.fastpeoplesearch.com/optout*",
        "https://www.peekyou.com/opt_out*",
        "https://suppression.peopleconnect.us/*",
        "https://www.beenverified.com/svc/optout/*",
        "https://www.peoplefinders.com/opt-out*",
        "https://members.searchquarry.com/opt-out*",
        "https://recordsfinder.com/optout/*",
        "https://infotracer.com/optout/*",
        "https://staterecords.org/optout*",
        "https://www.familytreenow.com/optout*",
        "https://www.cyberbackgroundchecks.com/removal*",
        "https://www.smartbackgroundchecks.com/optout*",
        "https://www.idcrawl.com/remove-my-information*",
        "https://www.whitepages.com/suppression-requests*",
        "https://radaris.com/control-privacy*",
        "https://optout.lexisnexis.com/*",
        "https://www.spokeo.com/optout*",
        "https://facecheck.id/Face-Search/RemoveMyPhotos*",
        "https://pimeyes.com/en/opt-out-request-form*",
        "https://www.equifax.com/personal/privacy/*",
        "https://www.experian.com/privacy/center.html*",
        "https://www.transunion.com/consumer-privacy*",
        "https://www.lusha.com/privacy-policy/*",
        "https://rocketreach.co/privacy*",
        "https://hunter.io/privacy*"
      ],
      "js": ["brokers.js", "optout.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
